{
  "name": "ctx-plugin",
  "version": "0.1.0",
  "description": "CTX — Universal plugin for AI CLI systems (Claude Code, Gemini CLI, OpenCode, Codex CLI). Multi-provider orchestration with consilium (CBDP), knowledge base, and adaptive routing",
  "type": "module",
  "main": "scripts/ctx-mcp-hub.js",
  "bin": {
    "ctx": "scripts/ctx-cli.js",
    "ctx-plugin": "scripts/ctx-setup.js",
    "ctx-install": "scripts/ctx-setup.js"
  },
  "exports": {
    ".": "./scripts/ctx-mcp-hub.js",
    "./cli": "./scripts/ctx-cli.js",
    "./consilium": "./src/consilium/round-orchestrator.js",
    "./config": "./src/core/config/resolve-config.js"
  },
  "files": [
    "src/",
    "scripts/",
    "bin/",
    "skills/",
    "agents/",
    "commands/",
    "hooks/",
    "consilium.presets.json",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "node scripts/ctx-setup.js install 2>/dev/null || true",
    "install:providers": "node scripts/ctx-setup.js install",
    "update:providers": "node scripts/ctx-update-providers.js",
    "statusline:providers": "node scripts/provider-limits-statusline.js",
    "statusline:providers:watch": "node scripts/provider-limits-statusline.js --watch --interval=15",
    "test": "node --test --test-concurrency=1",
    "test:kb": "node --test --test-concurrency=1 --test-reporter=spec --test-reporter=./tests/helpers/kb-reporter.mjs --test-reporter-destination=stdout --test-reporter-destination=stderr",
    "test:mcp": "node scripts/ctx-mcp-hub.js"
  },
  "keywords": [
    "ai",
    "multi-provider",
    "consilium",
    "ai-cli",
    "claude-code",
    "gemini-cli",
    "opencode",
    "codex-cli",
    "mcp",
    "orchestration",
    "cbdp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VladPatr96/ctx.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "lru-cache": "^11.2.6",
    "zod": "^3.24.0"
  }
}
