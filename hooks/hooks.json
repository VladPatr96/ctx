{
  "hooks": {
    "PreCompress": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/ctx-session-save.js\" --event compact"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/ctx-session-save.js\" --event stop"
          }
        ]
      }
    ]
  }
}
